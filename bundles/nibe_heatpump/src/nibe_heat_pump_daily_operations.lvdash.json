{
  "datasets": [
    {
      "displayName": "Summary KPIs",
      "name": "ds_summary",
      "queryLines": [
        "SELECT   COUNT(DISTINCT log_date) AS total_days,   ROUND(AVG(outdoor_avg_c), 1) AS avg_outdoor_c,   ROUND(AVG(supply_avg_c), 1) AS avg_supply_c,   ROUND(AVG(superheat_avg_k), 1) AS avg_superheat_k,   ROUND(AVG(delta_t_avg_k), 1) AS avg_delta_t_k,   ROUND(AVG(CAST(compr_duty_pct AS DOUBLE)), 0) AS avg_compr_duty,   ROUND(SUM(heater_kwh), 0) AS total_heater_kwh FROM dev_raw.nibe.gold_nibe_hourly_detail "
      ]
    },
    {
      "displayName": "Daily Trend",
      "name": "ds_daily",
      "queryLines": [
        "SELECT   log_date,   ROUND(AVG(outdoor_avg_c), 1) AS outdoor_avg_c,   ROUND(AVG(supply_avg_c), 1) AS supply_avg_c,   ROUND(AVG(superheat_avg_k), 1) AS superheat_avg_k,   ROUND(AVG(delta_t_avg_k), 1) AS delta_t_avg_k,   ROUND(AVG(CAST(compr_duty_pct AS DOUBLE)), 0) AS compr_duty_pct,   ROUND(SUM(heater_kwh), 1) AS heater_kwh_day FROM dev_raw.nibe.gold_nibe_hourly_detail GROUP BY log_date ORDER BY log_date "
      ]
    },
    {
      "displayName": "Alarm Episodes",
      "name": "ds_alarms",
      "queryLines": [
        "SELECT   log_date,   alarm_number,   CAST(start_time AS STRING) AS start_time_str,   ROUND(duration_min, 1) AS duration_min,   ROUND(outdoor_avg_c, 1) AS outdoor_avg_c,   ROUND(superheat_avg_k, 1) AS superheat_avg_k,   ROUND(delta_t_avg_k, 1) AS delta_t_avg_k,   ROUND(hp_avg_bar, 1) AS hp_avg_bar,   ROUND(discharge_avg_c, 1) AS discharge_avg_c FROM dev_raw.nibe.gold_nibe_alarm_episodes ORDER BY log_date, episode_id "
      ]
    },
    {
      "displayName": "Data Quality",
      "name": "ds_quality",
      "queryLines": [
        "SELECT   log_date,   total_samples,   ROUND(CAST(coverage_pct AS DOUBLE), 1) AS coverage_pct,   ROUND(CAST(logged_hours AS DOUBLE), 1) AS logged_hours,   max_gap_seconds FROM dev_raw.nibe.gold_nibe_data_quality ORDER BY log_date "
      ]
    }
  ],
